<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.shape.*?>

<VBox prefHeight="750.0" prefWidth="1100.0" spacing="0" stylesheets="/css/audit-ai.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.audit.auditaifx.controller.MainController">


    <HBox VBox.vgrow="ALWAYS">
        <StackPane HBox.hgrow="ALWAYS">
            
            <!-- VIEW 1: DASHBOARD -->
            <ScrollPane fx:id="dashboardView" fitToWidth="true" style="-fx-background-color: #f4f7f6;">
                <VBox alignment="TOP_CENTER" spacing="25" style="-fx-padding: 30;">
                    <Label style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #1a237e;" text="Tableau de Bord Analytique" />
                    
                    <FlowPane alignment="CENTER" hgap="20" vgap="20">
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Total Rapports" />
                            <Label fx:id="lblDashTotalRapports" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #3498db;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Recommandations" />
                            <Label fx:id="lblDashTotalReco" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #e67e22;" text="0" />
                        </VBox>
                        <VBox alignment="CENTER" prefHeight="120" prefWidth="180" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-size: 13; -fx-text-fill: #7f8c8d;" text="Résolution" />
                            <Label fx:id="lblDashTaux" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" text="0%" />
                        </VBox>
                    </FlowPane>

                    <HBox spacing="20" alignment="CENTER">
                        <VBox spacing="10" prefWidth="450" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📊 Répartition par Statut" />
                            <PieChart fx:id="chartStatut" prefHeight="250" legendVisible="false" />
                        </VBox>
                        <VBox spacing="10" prefWidth="450" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                            <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📊 Priorités des Recommandations" />
                            <BarChart fx:id="chartPriorite" prefHeight="250" legendVisible="false">
                                <xAxis><CategoryAxis label="Priorité" /></xAxis>
                                <yAxis><NumberAxis label="Nombre" /></yAxis>
                            </BarChart>
                        </VBox>
                    </HBox>

                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="📈 Tendance des créations d'audits" />
                        <LineChart fx:id="chartTendance" prefHeight="200" legendVisible="false">
                            <xAxis><CategoryAxis label="Date" /></xAxis>
                            <yAxis><NumberAxis label="Nombre de rapports" /></yAxis>
                        </LineChart>
                    </VBox>

                    <!-- AI CARD -->
                    <VBox fx:id="vboxAICard" spacing="0" style="-fx-background-color: linear-gradient(to right, #1a237e, #7b1fa2); -fx-background-radius: 15;">
                        <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 16 20 12 20;">
                            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;" text="✨ Recommandation IA — Priorité" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnRefreshAI" onAction="#refreshAIRecommendation" style="-fx-background-color: #3949ab; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 4 14; -fx-cursor: hand;" text="Actualiser" />
                        </HBox>
                        <VBox spacing="12" style="-fx-background-color: white; -fx-background-radius: 0 0 15 15; -fx-padding: 18 20;">
                            <HBox spacing="15" alignment="CENTER_LEFT">
                                <VBox alignment="CENTER" prefWidth="60" prefHeight="60" style="-fx-background-color: #fdf0f0; -fx-background-radius: 30; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 30;">
                                    <Label fx:id="lblAIPriorityBadge" style="-fx-font-size: 24;" text="🔴" />
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label fx:id="lblAIRapportTitre" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Chargement..." wrapText="true" />
                                    <Label fx:id="lblAIRaison" style="-fx-font-size: 13; -fx-text-fill: #555;" wrapText="true" />
                                </VBox>
                                <Button fx:id="btnVoirRapportAI" onAction="#voirRapportPrioritaire" style="-fx-background-color: #1a237e; -fx-text-fill: white; -fx-background-radius: 8; -fx-padding: 10 20; -fx-font-weight: bold;" text="Voir →" />
                            </HBox>
                            <HBox spacing="20" alignment="CENTER_LEFT">
                                <ProgressBar fx:id="progressPrioriteAI" prefWidth="200" prefHeight="10" progress="0.0" style="-fx-accent: #e74c3c;" />
                                <Label fx:id="lblScoreAI" style="-fx-font-size: 11px; -fx-text-fill: #e74c3c; -fx-font-weight: bold;" text="0/100" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label fx:id="lblAIDetail" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                            </HBox>
                        </VBox>
                    </VBox>

                    <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                        <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="🕒 Activités Récentes" />
                        <VBox fx:id="vboxRecentReports" spacing="10" />
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- VIEW 2: REPORTS LIST -->
            <VBox fx:id="allReportsView" spacing="10" style="-fx-background-color: #f4f7f6; -fx-padding: 20;" visible="false">
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 6, 0, 0, 2);">
                    <TextField fx:id="txtSearchReports" prefWidth="180" promptText="🔍 Rechercher..." />
                    <ComboBox fx:id="comboFilterStatut" prefWidth="130" promptText="Statut" />
                    <ComboBox fx:id="comboFilterNom" prefWidth="140" promptText="Auditeur" />
                    <Button onAction="#resetFilters" text="Initialiser" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#ajouterRapport" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;" text="+ Nouveau Rapport" />
                </HBox>

                <TableView fx:id="rapportsTable" VBox.vgrow="ALWAYS">
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colTitre" prefWidth="350" text="Titre" />
                        <TableColumn fx:id="colAuditeur" prefWidth="180" text="Catégorie" />
                        <TableColumn fx:id="colDate" prefWidth="150" text="Date" />
                        <TableColumn fx:id="colStatut" prefWidth="120" text="Score (%)" />
                        <TableColumn fx:id="colActionsRapport" prefWidth="150" text="Actions" />
                    </columns>
                </TableView>

                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Button fx:id="btnPrevPage" onAction="#pagePrev" text="‹ Préc" />
                    <Label fx:id="lblPageInfo" style="-fx-font-weight: bold;" text="1 / 1" />
                    <Button fx:id="btnNextPage" onAction="#pageNext" text="Suiv ›" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="lblTotalFiltered" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" />
                </HBox>
            </VBox>

            <!-- VIEW 3: DETAILS -->
            <ScrollPane fx:id="detailView" fitToWidth="true" style="-fx-background-color: #f4f7f6;" visible="false">
                <VBox spacing="15" style="-fx-padding: 25;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Button onAction="#showAllReports" text="← Retour" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#modifierRapportSelectionne" text="Modifier" />
                        <Button onAction="#supprimerRapportSelectionne" text="Supprimer" />
                        <Button onAction="#genererRecoIA" fx:id="btnAnalyserIA" text="✨ Recos IA" />
                        <Button onAction="#calculerScoreAudit" fx:id="btnDetecterRisques" text="📊 Score" />
                        <Button onAction="#genererRisquesIA" text="⚠️ Détecter Risques" />
                        <Label fx:id="lblScoreBadge" styleClass="score-badge" visible="false" managed="false" />
                    </HBox>

                    <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="lblSelectedTitre" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1a237e;" wrapText="true" HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblStatutBadge" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 3 12; -fx-font-weight: bold;" />
                        </HBox>
                        <Separator />
                        <GridPane hgap="40" vgap="10">
                            <Label text="Entité :" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblInfoEntite" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                            <Label text="Auditeur :" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblInfoAuditeur" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                            <Label text="Créé le :" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblDateCreation" GridPane.rowIndex="0" GridPane.columnIndex="3" />
                            <Label text="Mis à jour :" GridPane.rowIndex="1" GridPane.columnIndex="2" style="-fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblSelectedSub" GridPane.rowIndex="1" GridPane.columnIndex="3" />
                        </GridPane>
                        <Separator />
                        <Label text="DESCRIPTION" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                        <Label fx:id="txtDescriptionRapport" wrapText="true" style="-fx-line-spacing: 3;" />
                        <Separator />
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="SCORE DE RÉSOLUTION" style="-fx-font-weight: bold; -fx-text-fill: #7f8c8d;" />
                            <Label fx:id="lblScoreResolution" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;" text="0%" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblRecoStats" style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;" />
                        </HBox>
                        <ProgressBar fx:id="progressResolution" prefWidth="99999" prefHeight="12" progress="0.0" />
                    </VBox>

                    <VBox spacing="8">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="📌 Recommandations" style="-fx-font-size: 16; -fx-font-weight: bold;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="btnAjouterReco" onAction="#ajouterRecommandation" text="+ Ajouter" />
                        </HBox>
                        <TableView fx:id="recoTable" prefHeight="250">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colRecoDesc" prefWidth="300" text="Description" />
                                <TableColumn fx:id="colRecoPriorite" prefWidth="100" text="Priorité" />
                                <TableColumn fx:id="colRecoResolue" prefWidth="100" text="Résolue" />
                                <TableColumn fx:id="colActionsReco" prefWidth="180" text="Actions" />
                            </columns>
                        </TableView>
                    </VBox>

                    <VBox spacing="8">
                        <Label text="⚠️ Risques Détectés" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #c0392b;" />
                        <TableView fx:id="risqueTable" prefHeight="200">
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colRisqueAlerte" prefWidth="50" text="!" />
                                <TableColumn fx:id="colRisqueNiveau" prefWidth="100" text="Niveau" />
                                <TableColumn fx:id="colRisqueDesc" prefWidth="330" text="Description" />
                                <TableColumn fx:id="colRisqueImpact" prefWidth="230" text="Impact" />
                                <TableColumn fx:id="colActionsRisque" prefWidth="100" text="Actions" />
                            </columns>
                        </TableView>
                    </VBox>
                </VBox>
            </ScrollPane>
        </StackPane>
    </HBox>

    <!-- FOOTER -->
    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-padding: 10 20; -fx-background-color: white; -fx-border-color: #e8eaf6 transparent transparent transparent;">
        <Label fx:id="lblTotalRapports" style="-fx-font-weight: bold;" text="0 rapport(s)" />
        <Label fx:id="lblTotalReco" style="-fx-font-weight: bold;" text="0 recommandation(s)" />
        <Region HBox.hgrow="ALWAYS" />
        <Label style="-fx-text-fill: #95a5a6; -fx-font-size: 11px;" text="AuditAI Analytics v3.0" />
    </HBox>

</VBox>