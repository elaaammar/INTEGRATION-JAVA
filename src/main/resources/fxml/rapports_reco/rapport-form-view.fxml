<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.audit.auditaifx.controller.RapportFormController"
            fitToWidth="true" style="-fx-background-color: #f8fafc;">
    <VBox spacing="12" style="-fx-padding: 25;" stylesheets="@../../css/audit-ai.css">
        <!-- TITRE FORMULAIRE -->
        <Label text="📋 Rapport d'Audit" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        <Separator/>

        <!-- TITRE -->
        <VBox spacing="3">
            <Label text="Titre *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtTitre" promptText="Ex: Audit Sécurité SI 2024"/>
            <Label fx:id="lblErreurTitre" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;"/>
        </VBox>

        <!-- CATEGORIE (ex-Auditeur) -->
        <VBox spacing="3">
            <Label text="Catégorie *" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtAuditeur" promptText="Ex: Cybersécurité, Conformité..."/>
            <Label fx:id="lblErreurAuditeur" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;"/>
        </VBox>

        <!-- DATE (ex-Entite) -->
        <VBox spacing="3">
            <Label text="Date *" style="-fx-font-weight: bold;"/>
            <DatePicker fx:id="dpDate" prefWidth="Infinity" promptText="Sélectionner la date"/>
            <Label fx:id="lblErreurEntite" style="-fx-text-fill: #e74c3c; -fx-font-size: 11;"/>
        </VBox>

        <!-- SCORE (ex-Statut) -->
        <VBox spacing="3">
            <Label text="Score (%)" style="-fx-font-weight: bold;"/>
            <TextField fx:id="txtScore" promptText="Ex: 85"/>
        </VBox>

        <!-- DESCRIPTION -->
        <VBox spacing="3">
            <Label text="Description" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="txtDescription" promptText="Description du rapport..." prefHeight="100" wrapText="true"/>
        </VBox>

        <Separator/>

        <!-- BOUTONS -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#annuler" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 20;"/>
            <Button text="💾 Sauvegarder" onAction="#sauvegarder" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 8 20;"/>
        </HBox>
    </VBox>
</ScrollPane>