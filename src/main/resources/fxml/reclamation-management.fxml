<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mindjavafx.controller.ReclamationManagementController"
            style="-fx-background-color: #f1f5f9;">

    <!-- ══════════════ TOP BAR ══════════════ -->
    <top>
        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),8,0,0,2);">
            <!-- Title row -->
            <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-padding: 20 28 12 28;">
                <VBox spacing="3">
                    <Label text="📬  Gestion des Réclamations"
                           style="-fx-font-size: 22; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                    <Label text="Suivez, traitez et répondez aux réclamations en temps réel"
                           style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblTotal"  text="0 total"  style="-fx-background-color: #dbeafe; -fx-text-fill: #1d4ed8; -fx-font-size: 12; -fx-font-weight: 700; -fx-padding: 5 14; -fx-background-radius: 20;"/>
                <Label fx:id="lblEnAttente" text="0 en attente" style="-fx-background-color: #fef3c7; -fx-text-fill: #b45309; -fx-font-size: 12; -fx-font-weight: 700; -fx-padding: 5 14; -fx-background-radius: 20;"/>
                <Label fx:id="lblResolues"  text="0 résolues"  style="-fx-background-color: #d1fae5; -fx-text-fill: #047857; -fx-font-size: 12; -fx-font-weight: 700; -fx-padding: 5 14; -fx-background-radius: 20;"/>
                <Button text="⟳  Actualiser" onAction="#refreshList"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 8;
                               -fx-padding: 9 18; -fx-font-weight: bold; -fx-font-size: 12; -fx-cursor: hand;"/>
            </HBox>

            <!-- Search + filter row -->
            <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-padding: 0 28 16 28;">
                <TextField fx:id="searchField" promptText="🔍  Rechercher par titre, nom, email, catégorie…"
                           HBox.hgrow="ALWAYS"
                           style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                  -fx-background-radius: 8; -fx-padding: 9 14; -fx-font-size: 13;"/>
                <ComboBox fx:id="filterStatut" promptText="Statut" prefWidth="140"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <ComboBox fx:id="filterPriorite" promptText="Priorité" prefWidth="130"
                          style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8;"/>
                <Button text="Filtrer" onAction="#applyFilter"
                        style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-background-radius: 8;
                               -fx-padding: 9 18; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Réinitialiser" onAction="#resetFilter"
                        style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-background-radius: 8;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-padding: 9 18; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ══════════════ SPLIT PANEL ══════════════ -->
    <center>
        <SplitPane dividerPositions="0.42" style="-fx-background-color: #f1f5f9; -fx-padding: 0;">

            <!-- ── LEFT: Reclamation list ── -->
            <VBox style="-fx-background-color: #f1f5f9; -fx-padding: 16 8 16 16;">
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-background: transparent;">
                    <ListView fx:id="listReclamations" VBox.vgrow="ALWAYS"
                              style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;"/>
                </ScrollPane>
            </VBox>

            <!-- ── RIGHT: Detail + Reply panel ── -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: white; -fx-background: white;">
                <VBox fx:id="detailPanel" spacing="0"
                      style="-fx-background-color: white; -fx-min-width: 380;">

                    <!-- Placeholder when nothing selected -->
                    <VBox fx:id="placeholderPanel" alignment="CENTER" spacing="16"
                          style="-fx-padding: 80 40; -fx-background-color: white;" VBox.vgrow="ALWAYS">
                        <Label text="📋" style="-fx-font-size: 56;"/>
                        <Label text="Sélectionnez une réclamation"
                               style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                        <Label text="Choisissez une réclamation dans la liste\npour voir les détails et répondre."
                               style="-fx-font-size: 13; -fx-text-fill: #64748b; -fx-text-alignment: center; -fx-wrap-text: true;"/>
                    </VBox>

                    <!-- Detail content (hidden until selected) -->
                    <VBox fx:id="contentPanel" spacing="0" visible="false" managed="false">

                        <!-- Header detail -->
                        <VBox spacing="10" style="-fx-padding: 24 24 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="detailStatutBadge" text="EN ATTENTE"
                                       style="-fx-background-color: #fef3c7; -fx-text-fill: #b45309; -fx-font-size: 10;
                                              -fx-font-weight: 800; -fx-padding: 4 12; -fx-background-radius: 20;"/>
                                <Label fx:id="detailPrioriteBadge" text="HAUTE"
                                       style="-fx-background-color: #fee2e2; -fx-text-fill: #b91c1c; -fx-font-size: 10;
                                              -fx-font-weight: 800; -fx-padding: 4 12; -fx-background-radius: 20;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="detailCategorie" text=""
                                       style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                            </HBox>
                            <Label fx:id="detailTitre" text=""
                                   style="-fx-font-size: 18; -fx-font-weight: 800; -fx-text-fill: #0f172a; -fx-wrap-text: true;"/>
                            <Label fx:id="detailDate" text=""
                                   style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                        </VBox>

                        <!-- Client info -->
                        <VBox spacing="8" style="-fx-padding: 18 24; -fx-background-color: #f8fafc;
                                                  -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                            <Label text="INFORMATIONS CLIENT"
                                   style="-fx-font-size: 10; -fx-font-weight: 800; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1;"/>
                            <HBox spacing="20">
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label text="Nom" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                                    <Label fx:id="detailNom" text="—"
                                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                                </VBox>
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label text="Email" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                                    <Label fx:id="detailEmail" text="—"
                                           style="-fx-font-size: 13; -fx-text-fill: #2563eb;"/>
                                </VBox>
                                <VBox spacing="3">
                                    <Label text="Tél." style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
                                    <Label fx:id="detailTel" text="—"
                                           style="-fx-font-size: 13; -fx-text-fill: #0f172a;"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Description -->
                        <VBox spacing="8" style="-fx-padding: 18 24; -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                            <Label text="DESCRIPTION"
                                   style="-fx-font-size: 10; -fx-font-weight: 800; -fx-text-fill: #94a3b8;"/>
                            <Label fx:id="detailDescription" text="—"
                                   style="-fx-font-size: 13; -fx-text-fill: #334155; -fx-wrap-text: true;"/>
                        </VBox>

                        <!-- Change status -->
                        <HBox alignment="CENTER_LEFT" spacing="10"
                              style="-fx-padding: 14 24; -fx-background-color: #f8fafc;
                                     -fx-border-color: #f1f5f9; -fx-border-width: 0 0 1 0;">
                            <Label text="Changer statut :"
                                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <ComboBox fx:id="comboNewStatut" prefWidth="150"
                                      style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 6; -fx-background-radius: 6;"/>
                            <Button text="Appliquer" onAction="#applyStatutChange"
                                    style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 6;
                                           -fx-padding: 7 16; -fx-font-weight: bold; -fx-font-size: 12; -fx-cursor: hand;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="🗑" onAction="#deleteReclamation"
                                    style="-fx-background-color: #fee2e2; -fx-text-fill: #b91c1c; -fx-background-radius: 6;
                                           -fx-padding: 7 12; -fx-cursor: hand; -fx-font-size: 14;"/>
                        </HBox>

                        <!-- Conversation / Replies -->
                        <VBox spacing="0" style="-fx-padding: 0;">
                            <Label text="CONVERSATION"
                                   style="-fx-font-size: 10; -fx-font-weight: 800; -fx-text-fill: #94a3b8;
                                          -fx-padding: 14 24 10 24;"/>
                            <ScrollPane fx:id="scrollReplies" fitToWidth="true" prefHeight="200"
                                        style="-fx-background-color: #f8fafc; -fx-background: #f8fafc; -fx-padding: 0 12;">
                                <VBox fx:id="repliesContainer" spacing="10"
                                      style="-fx-padding: 10 12;"/>
                            </ScrollPane>
                        </VBox>

                        <!-- Reply box -->
                        <VBox spacing="10" style="-fx-padding: 16 24 20 24; -fx-border-color: #f1f5f9; -fx-border-width: 1 0 0 0;">
                            <Label text="RÉPONDRE"
                                   style="-fx-font-size: 10; -fx-font-weight: 800; -fx-text-fill: #94a3b8;"/>
                            <TextArea fx:id="replyField" promptText="Saisissez votre réponse officielle…"
                                      prefRowCount="3" wrapText="true"
                                      style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                             -fx-background-radius: 8; -fx-font-size: 13; -fx-padding: 10;"/>
                            <HBox alignment="CENTER_RIGHT" spacing="10">
                                <Button text="✉  Envoyer la réponse" onAction="#sendReply"
                                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 8;
                                               -fx-padding: 10 20; -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>

</BorderPane>
