<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mindjavafx.controller.AuditorDashboardController"
            stylesheets="@../css/styles.css">

    <!-- HEADER (TOP) -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: #0B132B; -fx-border-bottom-width: 2px; -fx-border-color: #1C2541 #1C2541 #00E5FF #1C2541; -fx-padding: 15px 30px;">
            <!-- Logo/Title -->
            <HBox alignment="CENTER" spacing="10">
                <Label text="MindAudit" style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="AI CORE" style="-fx-text-fill: #00E5FF; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: rgba(0, 229, 255, 0.1); -fx-padding: 3px 8px; -fx-background-radius: 4px; -fx-border-color: #00E5FF; -fx-border-radius: 4px;"/>
            </HBox>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- AI Welcome Message -->
            <VBox alignment="CENTER">
                <Label text="Système d'Audit IA Initialisé" style="-fx-text-fill: #48CAE4; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                <Label text="Mode Analyse Avancée : ACTIF 🟢" style="-fx-text-fill: #00FF00; -fx-font-size: 11px; -fx-font-family: 'Consolas', monospace;"/>
            </VBox>
            
            <Region HBox.hgrow="ALWAYS"/>
            
            <!-- User Info -->
            <HBox alignment="CENTER" spacing="15">
                <Label text="Terminal Sécurisé" style="-fx-text-fill: #8D99AE; -fx-font-size: 12px; -fx-font-family: 'Consolas', monospace;"/>
                <!-- Logout Button -->
                <Button fx:id="logoutButton" text="Terminer Session" onAction="#handleLogout"
                       style="-fx-background-color: transparent; -fx-border-color: #e74c3c; -fx-text-fill: #e74c3c; -fx-border-radius: 5px; -fx-padding: 6px 15px; -fx-cursor: hand; -fx-font-family: 'Consolas', monospace;"/>
            </HBox>
        </HBox>
    </top>

    <!-- SIDEBAR MODERNE IA -->
    <left>
        <VBox spacing="8" style="-fx-background-color: #1C2541; -fx-padding: 25 0; -fx-border-right-width: 1px; -fx-border-color: #1C2541 #2b395e #1C2541 #1C2541;" prefWidth="250">
            <Label text="MODULES D'INTELLIGENCE" style="-fx-font-weight: bold; -fx-font-size: 11; -fx-text-fill: #00E5FF; -fx-padding: 10 25; -fx-letter-spacing: 2;"/>
            
            <!-- Dashboard Removed for Auditor -->
            
            <Button fx:id="auditsButton" text="⚙️ Traitement des Audits" onAction="#showAuditManagement" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #E0E1DD; -fx-alignment: CENTER_LEFT; -fx-padding: 15px 25px; -fx-font-size: 13px; -fx-cursor: hand; -fx-font-family: 'Consolas', monospace;"/>

            <Button fx:id="newReportButton" text="   [+] Générer Rapport" onAction="#showAddRapport" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #778DA9; -fx-alignment: CENTER_LEFT; -fx-padding: 10px 45px; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-family: 'Consolas', monospace;"/>

            <Button fx:id="newQuestionButton" text="   [?] Formuler Question" onAction="#showAddQuestion" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #778DA9; -fx-alignment: CENTER_LEFT; -fx-padding: 10px 45px; -fx-font-size: 12px; -fx-cursor: hand; -fx-font-family: 'Consolas', monospace;"/>

            <Button fx:id="reportsButton" text="📊 Base de Connaissances" onAction="#showRapportManagement" maxWidth="Infinity"
                    style="-fx-background-color: transparent; -fx-text-fill: #E0E1DD; -fx-alignment: CENTER_LEFT; -fx-padding: 15px 25px; -fx-font-size: 13px; -fx-cursor: hand; -fx-font-family: 'Consolas', monospace;"/>
            
            <!-- Notifications Removed for Auditor -->
            
            <!-- Separator -->
            <VBox style="-fx-padding: 20 0;"/>
            
            <!-- SYSTEM and Profile Removed for Auditor -->
            
            <Region VBox.vgrow="ALWAYS"/>
            <VBox alignment="CENTER" spacing="5" style="-fx-padding: 15;">
                <Label text="AI Engine v2.4.1" style="-fx-text-fill: #00E5FF; -fx-font-size: 10px; -fx-font-family: 'Consolas', monospace;"/>
                <ProgressBar progress="1.0" prefWidth="180" prefHeight="5" style="-fx-accent: #00E5FF;"/>
                <Label text="Ressources Systèmes: OPTIMAL" style="-fx-text-fill: #778DA9; -fx-font-size: 9px; -fx-font-family: 'Consolas', monospace;"/>
            </VBox>
        </VBox>
    </left>

    <!-- CONTENT AREA (CENTER) -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
            <!-- Content will be loaded dynamically here -->
        </StackPane>
    </center>

</BorderPane>
