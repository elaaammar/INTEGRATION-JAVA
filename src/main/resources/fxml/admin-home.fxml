<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f1f5f9; -fx-background: #f1f5f9;"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mindjavafx.controller.AdminDashboardHomeController">

    <VBox spacing="24" style="-fx-padding: 28; -fx-background-color: #f1f5f9;">

        <!-- ══════════════════ HEADER ══════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="12">
            <VBox spacing="4">
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Tableau de bord" style="-fx-font-size: 13; -fx-text-fill: #64748b; -fx-font-weight: 600;"/>
                </HBox>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Bonjour," style="-fx-font-size: 26; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                    <Label fx:id="welcomeNameLabel" text="Administrateur"
                           style="-fx-font-size: 26; -fx-font-weight: 800; -fx-text-fill: #2563eb;"/>
                </HBox>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <VBox alignment="CENTER_RIGHT" spacing="4">
                <Label fx:id="lblLastRefresh" text="—"
                       style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                <Button text="⟳  Actualiser" onAction="#refreshData"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 8;
                               -fx-padding: 9 20; -fx-font-weight: bold; -fx-font-size: 13; -fx-cursor: hand;"/>
            </VBox>
        </HBox>

        <!-- ══════════════════ KPI CARDS (2 rows × 3) ══════════════════ -->
        <GridPane hgap="16" vgap="16">
            <columnConstraints>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3"/>
                <ColumnConstraints hgrow="ALWAYS" percentWidth="33.3"/>
            </columnConstraints>

            <!-- Card: Score Global -->
            <VBox spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="0" prefHeight="130"
                  style="-fx-background-color: linear-gradient(to bottom right,#2563eb,#1d4ed8);
                         -fx-background-radius: 14; -fx-padding: 20 22;
                         -fx-effect: dropshadow(gaussian,rgba(37,99,235,0.35),18,0,0,6);">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🎯" style="-fx-font-size: 20;"/>
                    <Label text="Score Moyen Global" style="-fx-font-size: 12; -fx-text-fill: rgba(255,255,255,0.75); -fx-font-weight: 700;"/>
                </HBox>
                <HBox alignment="BOTTOM_LEFT" spacing="6">
                    <Label fx:id="lblScoreGlobal" text="--" style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: white;"/>
                    <Label fx:id="lblScoreSubtitle" text="/ 100" style="-fx-font-size: 14; -fx-text-fill: rgba(255,255,255,0.6); -fx-padding: 0 0 6 0;"/>
                </HBox>
                <Label fx:id="lblScoreTrend" text="—" style="-fx-font-size: 11; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-weight: bold;"/>
            </VBox>

            <!-- Card: Total Audits -->
            <VBox spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="0" prefHeight="130"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="📄" style="-fx-font-size: 20;"/>
                    <Label text="Rapports d'Audit" style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: 700;"/>
                </HBox>
                <Label fx:id="lblTotalReports" text="0" style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <Label fx:id="lblAuditsTrend" text="—" style="-fx-font-size: 11; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Card: Recommandations -->
            <VBox spacing="12" GridPane.columnIndex="2" GridPane.rowIndex="0" prefHeight="130"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="💡" style="-fx-font-size: 20;"/>
                    <Label text="Recommandations" style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: 700;"/>
                </HBox>
                <Label fx:id="lblTotalRecos" text="0" style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <HBox spacing="10">
                    <Label fx:id="lblResolutionRate" text="0% résolues" style="-fx-font-size: 11; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>
                    <Label text="·" style="-fx-text-fill: #94a3b8;"/>
                    <Label fx:id="lblRecosTrend" text="—" style="-fx-font-size: 11; -fx-text-fill: #ef4444; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <!-- Card: Entreprises -->
            <VBox spacing="12" GridPane.columnIndex="0" GridPane.rowIndex="1" prefHeight="120"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🏢" style="-fx-font-size: 20;"/>
                    <Label text="Entreprises" style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: 700;"/>
                </HBox>
                <Label fx:id="lblTotalEntreprises" text="0" style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <Label fx:id="lblEntrepriseTrend" text="inscrites" style="-fx-font-size: 11; -fx-text-fill: #f59e0b; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Card: Utilisateurs -->
            <VBox spacing="12" GridPane.columnIndex="1" GridPane.rowIndex="1" prefHeight="120"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="👥" style="-fx-font-size: 20;"/>
                    <Label text="Utilisateurs" style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: 700;"/>
                </HBox>
                <Label fx:id="lblTotalUsers" text="0" style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <Label fx:id="lblActiveUsers" text="—" style="-fx-font-size: 11; -fx-text-fill: #10b981; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Card: Alertes -->
            <VBox spacing="12" GridPane.columnIndex="2" GridPane.rowIndex="1" prefHeight="120"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 20 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="🔔" style="-fx-font-size: 20;"/>
                    <Label text="Alertes non lues" style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-font-weight: 700;"/>
                </HBox>
                <Label fx:id="lblNotifications" text="0" style="-fx-font-size: 36; -fx-font-weight: 800; -fx-text-fill: #ef4444;"/>
                <Label text="notifications" style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
            </VBox>
        </GridPane>

        <!-- ══════════════════ CHARTS ROW 1 ══════════════════ -->
        <HBox spacing="16">
            <!-- Line Chart: Audits par mois -->
            <VBox spacing="12" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <Label text="📈  Activité des Audits — 6 derniers mois"
                       style="-fx-font-size: 14; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <Label text="Nombre d'audits créés par mois"
                       style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                <LineChart fx:id="chartTendance" prefHeight="230" animated="true"
                           legendVisible="false" createSymbols="true">
                    <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                    <yAxis><NumberAxis side="LEFT" lowerBound="0" tickUnit="1"/></yAxis>
                </LineChart>
            </VBox>

            <!-- Pie Chart: Statut des rapports -->
            <VBox spacing="12" prefWidth="320"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <Label text="📊  Statut des Rapports"
                       style="-fx-font-size: 14; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <Label text="Répartition par statut"
                       style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                <PieChart fx:id="chartStatus" prefHeight="230" animated="true" legendSide="BOTTOM"/>
            </VBox>
        </HBox>

        <!-- ══════════════════ CHARTS ROW 2 ══════════════════ -->
        <HBox spacing="16">
            <!-- Bar Chart: Priorités recommandations -->
            <VBox spacing="12" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <Label text="🏷️  Priorités des Recommandations"
                       style="-fx-font-size: 14; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <Label text="Nombre total par niveau de priorité"
                       style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                <BarChart fx:id="chartPriorities" prefHeight="210" animated="true" legendVisible="false">
                    <xAxis><CategoryAxis side="BOTTOM"/></xAxis>
                    <yAxis><NumberAxis side="LEFT" tickUnit="1"/></yAxis>
                </BarChart>

                <!-- Progress bars breakdown -->
                <VBox spacing="12" style="-fx-padding: 8 0 0 0;">
                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="🔴  Haute" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 12;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblPbHaute" text="—" style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-font-size: 12;"/>
                        </HBox>
                        <ProgressBar fx:id="pbHaute" progress="0" maxWidth="Infinity" prefHeight="8"
                                     style="-fx-accent: #ef4444; -fx-background-radius: 5;"/>
                    </VBox>
                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="🟡  Moyenne" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 12;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblPbMoyenne" text="—" style="-fx-text-fill: #f59e0b; -fx-font-weight: bold; -fx-font-size: 12;"/>
                        </HBox>
                        <ProgressBar fx:id="pbMoyenne" progress="0" maxWidth="Infinity" prefHeight="8"
                                     style="-fx-accent: #f59e0b; -fx-background-radius: 5;"/>
                    </VBox>
                    <VBox spacing="5">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="🟢  Faible" style="-fx-font-weight: bold; -fx-text-fill: #0f172a; -fx-font-size: 12;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblPbFaible" text="—" style="-fx-text-fill: #10b981; -fx-font-weight: bold; -fx-font-size: 12;"/>
                        </HBox>
                        <ProgressBar fx:id="pbFaible" progress="0" maxWidth="Infinity" prefHeight="8"
                                     style="-fx-accent: #10b981; -fx-background-radius: 5;"/>
                    </VBox>
                </VBox>
            </VBox>

            <!-- Pie Chart: Rôles utilisateurs -->
            <VBox spacing="12" prefWidth="320"
                  style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 22;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
                <Label text="👤  Répartition des Rôles"
                       style="-fx-font-size: 14; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
                <Label text="Distribution des utilisateurs par rôle"
                       style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
                <PieChart fx:id="chartUserRoles" prefHeight="310" animated="true" legendSide="BOTTOM"/>
            </VBox>
        </HBox>

        <!-- ══════════════════ ACTIVITÉ RÉCENTE ══════════════════ -->
        <VBox spacing="16"
              style="-fx-background-color: white; -fx-background-radius: 14; -fx-padding: 24;
                     -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 14;
                     -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.04),12,0,0,4);">
            <Label text="🕐  Activité Récente"
                   style="-fx-font-size: 14; -fx-font-weight: 800; -fx-text-fill: #0f172a;"/>
            <Label text="5 derniers audits enregistrés"
                   style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>

            <VBox spacing="10" style="-fx-padding: 4 0 0 0;">
                <Label fx:id="lblRecent1" text="—" style="-fx-font-size: 13; -fx-text-fill: #334155;"/>
                <Separator/>
                <Label fx:id="lblRecent2" text="—" style="-fx-font-size: 13; -fx-text-fill: #334155;"/>
                <Separator/>
                <Label fx:id="lblRecent3" text="—" style="-fx-font-size: 13; -fx-text-fill: #334155;"/>
                <Separator/>
                <Label fx:id="lblRecent4" text="—" style="-fx-font-size: 13; -fx-text-fill: #334155;"/>
                <Separator/>
                <Label fx:id="lblRecent5" text="—" style="-fx-font-size: 13; -fx-text-fill: #334155;"/>
            </VBox>
        </VBox>

        <!-- ══════════════════ ACTIONS RAPIDES ══════════════════ -->
        <HBox spacing="16">
            <VBox spacing="10" alignment="CENTER" onMouseClicked="#goToUserManagement" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12; -fx-cursor: hand;">
                <Label text="👥" style="-fx-font-size: 28;"/>
                <Label text="Utilisateurs" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Gérer les comptes" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER" onMouseClicked="#goToRolePermission" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12; -fx-cursor: hand;">
                <Label text="🔐" style="-fx-font-size: 28;"/>
                <Label text="Permissions" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Rôles &amp; Accès" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
            </VBox>

            <VBox spacing="10" alignment="CENTER" onMouseClicked="#goToEntrepriseManagement" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: white; -fx-padding: 24; -fx-background-radius: 12;
                         -fx-border-color: #e2e8f0; -fx-border-width: 1; -fx-border-radius: 12; -fx-cursor: hand;">
                <Label text="🏢" style="-fx-font-size: 28;"/>
                <Label text="Entreprises" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                <Label text="Validation &amp; Rejet" style="-fx-font-size: 11; -fx-text-fill: #64748b;"/>
            </VBox>
        </HBox>

    </VBox>
</ScrollPane>
