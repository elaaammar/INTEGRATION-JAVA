<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" styleClass="content-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlleur.AddQuestionController">
    <children>
        <VBox maxWidth="800.0" spacing="30.0" style="-fx-background-color: transparent; -fx-padding: 40 20;">
            <children>
                
                <!-- Titre façon Quillbot -->
                <VBox alignment="CENTER" spacing="10">
                    <Label text="Que dois-je demander à l'entreprise ?" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-family: 'Segoe UI', Arial, sans-serif;"/>
                    <Label text="L'IA MindAudit intègrera ces questions dans le flux d'audit interne." style="-fx-font-size: 16px; -fx-text-fill: #64748b; -fx-font-family: 'Segoe UI', Arial, sans-serif;"/>
                </VBox>

                <!-- Zone de saisie principale (Chat Input) -->
                <VBox style="-fx-background-color: white; -fx-background-radius: 12px; -fx-border-color: #cbd5e1; -fx-border-radius: 12px; -fx-padding: 15px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" spacing="15">
                    
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label text="📎" style="-fx-font-size: 18px; -fx-text-fill: #94a3b8;"/>
                        <TextField fx:id="tfContent" promptText="Saisissez la question ici (ex: Quel est le nom de votre entreprise ?)" style="-fx-background-color: transparent; -fx-font-size: 16px; -fx-prompt-text-fill: #94a3b8; -fx-text-fill: #1e293b;" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnAdd" onAction="#handleAddAction" text="➔" style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 50%; -fx-min-width: 40px; -fx-min-height: 40px; -fx-cursor: hand;"/>
                    </HBox>
                    
                    <Separator style="-fx-background-color: #f1f5f9;"/>

                    <!-- Paramètres avancés cachés discrètement en dessous -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <Label text="✨ Paramètres IA :" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                        
                        <ComboBox fx:id="cbType" promptText="Format de réponse" style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-size: 11px;" />
                        
                        <TextField fx:id="tfBonneReponse" promptText="Réponse attendue (Admin)" style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-size: 11px;" />
                        
                        <TextField fx:id="tfTimeLimit" promptText="Temps max (s)" style="-fx-background-color: #f8f9fa; -fx-border-color: #e2e8f0; -fx-border-radius: 6px; -fx-background-radius: 6px; -fx-font-size: 11px;" prefWidth="100"/>
                    </HBox>
                </VBox>

                <!-- Label de statut -->
                <HBox alignment="CENTER">
                    <Label fx:id="lblStatus" textAlignment="CENTER" wrapText="true" style="-fx-text-fill: #059669; -fx-font-weight: bold;"/>
                </HBox>

                <!-- Suggestions (Use Cases) -->
                <VBox spacing="15" style="-fx-padding: 20 0 0 0;">
                    <Label text="Suggestions de l'IA (Informations générales) :" style="-fx-font-size: 14px; -fx-text-fill: #64748b;"/>
                    
                    <HBox spacing="15">
                        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 15px;" prefWidth="250" HBox.hgrow="ALWAYS">
                            <Label text="🏢 Nom" style="-fx-font-weight: bold; -fx-text-fill: #059669; -fx-padding: 0 0 5 0;"/>
                            <Label text="Quel est le nom de votre entreprise ?" wrapText="true" style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 15px;" prefWidth="250" HBox.hgrow="ALWAYS">
                            <Label text="📊 Secteur" style="-fx-font-weight: bold; -fx-text-fill: #059669; -fx-padding: 0 0 5 0;"/>
                            <Label text="Quel est votre secteur d’activité ?" wrapText="true" style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 15px;" prefWidth="250" HBox.hgrow="ALWAYS">
                            <Label text="👥 Effectifs" style="-fx-font-weight: bold; -fx-text-fill: #059669; -fx-padding: 0 0 5 0;"/>
                            <Label text="Quelle est la taille de votre entreprise (nombre d’employés) ?" wrapText="true" style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>
                    </HBox>

                    <HBox spacing="15">
                        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 15px;" prefWidth="250" HBox.hgrow="ALWAYS">
                            <Label text="🌍 Régions" style="-fx-font-weight: bold; -fx-text-fill: #059669; -fx-padding: 0 0 5 0;"/>
                            <Label text="Dans quels pays ou régions opérez-vous ?" wrapText="true" style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8px; -fx-background-radius: 8px; -fx-padding: 15px;" prefWidth="250" HBox.hgrow="ALWAYS">
                            <Label text="📂 Organigramme" style="-fx-font-weight: bold; -fx-text-fill: #059669; -fx-padding: 0 0 5 0;"/>
                            <Label text="Pouvez-vous fournir l’organigramme de l’entreprise ? (upload)" wrapText="true" style="-fx-text-fill: #475569; -fx-font-size: 13px;"/>
                        </VBox>
                        <VBox style="-fx-background-color: transparent;" prefWidth="250" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
